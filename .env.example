# MCPRuntime environment template.
# Copy to .env and set the variables below. The .env file is gitignored.
# Do not commit real API keys or server URLs; use placeholders only.

# Option 1: OpenAI
OPENAI_API_KEY=your-openai-key-here

# Option 2: Azure OpenAI (replace with your resource and deployment)
# AZURE_OPENAI_API_KEY=your-azure-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
# AZURE_OPENAI_DEPLOYMENT_NAME=your-chat-deployment-name

# Optional: execution
# AGENT_EXECUTION_TIMEOUT=30
# AGENT_SANDBOX_TYPE=monty

# Demo: hostname che il container usa per raggiungere il proxy sull'host.
# Su Docker Desktop (Mac/Windows): host.docker.internal
# Su Linux con --add-host: host-gateway o l'IP del bridge (es. 172.17.0.1)
# SANDBOX_HOST=host.docker.internal

# Demo: URL base di OpenSandbox execd (REST API)
# OPENSANDBOX_URL=http://localhost:44772
